# Firmus Linux keyring install script

post_install() {
  cat << EOF
Firmus Linux keyring installed.

To add the Firmus signing key to pacman, run:
  # pacman-key --add /usr/share/firmus/keyring/firmus.gpg
  # pacman-key --lsign-key "Firmus Linux Signing Key"

Then enable the TCR repository in /etc/pacman.conf:
  [firmus]
  SigLevel = Required TrustedOnly
  Server = https://firmuslinux.github.io/firmuslinux/x86_64
EOF
}

post_upgrade() {
  post_install
}

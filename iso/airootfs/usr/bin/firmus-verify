#!/usr/bin/env bash
# Firmus Linux AUR Verify — Validate PKGBUILD against signed allowlist
set -euo pipefail

VERSION="1.0.0"
ALLOWLIST_URL="https://raw.githubusercontent.com/firmuslinux/firmuslinux/main/packages/tcr/aur-allowlist.json"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
NC='\033[0m'

log_info() { echo -e "${CYAN}[INFO]${NC} $*"; }
log_ok() { echo -e "${GREEN}[OK]${NC} $*"; }
log_warn() { echo -e "${YELLOW}[WARN]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }

usage() {
    cat <<EOF
firmus-verify — Verify AUR PKGBUILD against Firmus allowlist

Usage:
  firmus-verify <package-name>    Verify a package's PKGBUILD
  firmus-verify --update          Update local allowlist
  firmus-verify --help            Show this help

The allowlist contains SHA256 hashes of known-good PKGBUILDs
from the Arch User Repository. If a PKGBUILD hash does not
match, it may have been tampered with.
EOF
}

download_allowlist() {
    local output="/tmp/firmus-allowlist.json"
    log_info "Downloading allowlist from TCR..."
    if curl -sSfL "$ALLOWLIST_URL" -o "$output" 2>/dev/null; then
        log_ok "Allowlist downloaded"
        echo "$output"
    else
        log_error "Failed to download allowlist"
        return 1
    fi
}

verify_package() {
    local pkgname="$1"
    local allowlist
    allowlist=$(download_allowlist) || return 1

    log_info "Downloading PKGBUILD for '$pkgname' from AUR..."
    local pkgbuild_content
    pkgbuild_content=$(curl -sSfL "https://aur.archlinux.org/cgit/aur.git/plain/PKGBUILD?h=$pkgname" 2>/dev/null) || {
        log_error "Failed to download PKGBUILD for '$pkgname'"
        return 1
    }

    local sha
    sha=$(echo "$pkgbuild_content" | sha256sum | cut -d' ' -f1)

    local expected
    expected=$(jq -r ".packages[\"$pkgname\"] // empty" "$allowlist" 2>/dev/null)

    if [ -z "$expected" ]; then
        log_warn "'$pkgname' is not in the allowlist"
        log_info "Current SHA256: $sha"
        log_info "You can install it manually, but verify the contents first."
        return 1
    fi

    if [ "$sha" = "$expected" ]; then
        log_ok "'$pkgname' verified — PKGBUILD hash matches allowlist"
        return 0
    else
        log_error "'$pkgname' PKGBUILD hash MISMATCH!"
        log_info "Expected: $expected"
        log_info "Actual:   $sha"
        log_warn "This package may have been tampered with. Do not install."
        return 1
    fi
}

main() {
    case "${1:-}" in
        --help|-h)
            usage
            ;;
        --update|-u)
            download_allowlist >/dev/null
            log_ok "Allowlist cached to /tmp/firmus-allowlist.json"
            ;;
        *)
            if [ -z "${1:-}" ]; then
                usage
                exit 1
            fi
            verify_package "$1"
            ;;
    esac
}

main "$@"

# Firmus Linux GRUB configuration

GRUB_DEFAULT=saved
GRUB_TIMEOUT=5
GRUB_TIMEOUT_STYLE=menu
GRUB_DISTRIBUTOR="Firmus"
GRUB_CMDLINE_LINUX_DEFAULT="quiet splash loglevel=3 rd.systemd.show_status=auto"
GRUB_CMDLINE_LINUX=""

# NVIDIA modesetting (enabled unconditionally — safe on non-NVIDIA hardware)
GRUB_CMDLINE_LINUX_DEFAULT="$GRUB_CMDLINE_LINUX_DEFAULT nvidia_drm.modeset=1"

# Btrfs with autodefrag for SSDs
GRUB_CMDLINE_LINUX_DEFAULT="$GRUB_CMDLINE_LINUX_DEFAULT rootflags=autodefrag"

# Preload modules for btrfs and snapper
GRUB_PRELOAD_MODULES="part_gpt part_msdos btrfs ext4 fat"

GRUB_TERMINAL_INPUT=console
GRUB_TERMINAL_OUTPUT=gfxterm

# Theme
GRUB_THEME=/boot/grub/themes/firmus/theme.txt
GRUB_BACKGROUND=/boot/grub/themes/firmus/background.png

GRUB_DISABLE_RECOVERY=true
GRUB_DISABLE_OS_PROBER=false
GRUB_ENABLE_CRYPTODISK=y
GRUB_SAVEDEFAULT=true
